# =============================================================================
# VulnAgent-X Configuration
# =============================================================================

# --- LLM Provider -----------------------------------------------------------
# Supported providers:
#   "ollama"  – Ollama native API  (uses /api/generate)
#   "openai"  – OpenAI cloud OR any OpenAI-compatible server (uses /v1/chat/completions)
#   "mock"    – offline / testing (no real LLM calls)
VULNAGENTX_LLM_PROVIDER=ollama

# Default model used by all agents unless overridden below.
# For Ollama native, use the model tag as shown by `ollama list` (e.g. qwen2.5:8b).
# For OpenAI / OpenAI-compatible, use the model name your server expects.
VULNAGENTX_LLM_MODEL=qwen2.5:8b

# Base URL of the LLM service.
# - Ollama native:           http://127.0.0.1:11434        (default, can omit)
# - OpenAI cloud:            https://api.openai.com/v1     (default, can omit)
# - OpenAI-compatible local: http://<host>:<port>/v1       (MUST set this)
# VULNAGENTX_LLM_BASE_URL=http://127.0.0.1:11434

# API key.
# - OpenAI cloud: your real key (sk-...)
# - OpenAI-compatible local: set to any non-empty string if the server
#   doesn't require auth (the OpenAI SDK still expects the variable to exist).
# - Ollama native: not needed.
# OPENAI_API_KEY=sk-...

# ~~~ Quick-start examples ~~~
#
# A) Ollama running locally (native API):
#    VULNAGENTX_LLM_PROVIDER=ollama
#    VULNAGENTX_LLM_MODEL=qwen2.5:8b
#
# B) vLLM / LM Studio / LocalAI / any OpenAI-compatible server:
#    VULNAGENTX_LLM_PROVIDER=openai
#    VULNAGENTX_LLM_MODEL=qwen2.5:8b
#    VULNAGENTX_LLM_BASE_URL=http://192.168.1.50:8000/v1
#    OPENAI_API_KEY=not-needed
#
# C) OpenAI cloud:
#    VULNAGENTX_LLM_PROVIDER=openai
#    VULNAGENTX_LLM_MODEL=gpt-4o-mini
#    OPENAI_API_KEY=sk-...

# --- Per-Agent Model Overrides ----------------------------------------------
# Assign a different model to each specialist agent.
# Agents without an override use VULNAGENTX_LLM_MODEL as the fallback.
#
# Recommended strategy:
#   - Use a small/fast model (8B) for the semantic agent (high volume, simpler patterns)
#   - Use a larger model (32B/70B) for security and logic agents (complex reasoning)
#
# VULNAGENTX_MODEL_SEMANTIC_AGENT=qwen2.5:8b
# VULNAGENTX_MODEL_SECURITY_AGENT=qwen2.5:32b
# VULNAGENTX_MODEL_LOGIC_BUG_AGENT=qwen2.5:32b

# --- Analysis Settings ------------------------------------------------------
VULNAGENTX_USE_SEMGREP=true
VULNAGENTX_USE_TREESITTER=true
VULNAGENTX_ENABLE_SCEPTIC=true
VULNAGENTX_ENABLE_VERIFICATION=true

# --- Logging -----------------------------------------------------------------
VULNAGENTX_LOG_LEVEL=INFO
